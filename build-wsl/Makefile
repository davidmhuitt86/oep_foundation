oep_object_command_tests: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 oep_object_command_tests
.PHONY : oep_object_command_tests

# fast build rule for target.
oep_object_command_tests/fast:
	$(MAKE) $(MAKESILENT) -f tests/cli/CMakeFiles/oep_object_command_tests.dir/build.make tests/cli/CMakeFiles/oep_object_command_tests.dir/build
.PHONY : oep_object_command_tests/fast

