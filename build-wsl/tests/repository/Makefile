	cd /mnt/c/Users/david/OneDrive/Desktop/Projects/platform/oep_foundation/build-wsl && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
